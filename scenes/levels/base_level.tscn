[sub_resource type="GDScript" id="GDScript_8ohfs"]
script/source = "extends StaticBody2D

signal door_opened
# --- INVENTARUL TRUPELOR (PUNE ASTA SUS DE TOT) ---
@onready var quiz_ui = $\"../InterfataUI/QuizUi\"
@onready var ai_manager = $\"../ManagerAI\"
var keytaken = false
var in_door_zone = false
var cufar_curent_activ = null

func _ready() -> void:
	# Ne asigurăm că ușa pornește în starea corectă
	$Inchisa.show()
	$Deschisa.hide()
	
	# TACTICA DE REȚEA BLINDATĂ!
	var toate_cuferele = get_tree().get_nodes_in_group(\"Cufere\")
	for cufar in toate_cuferele:
		# Verificăm actele înainte să dăm ordine! Masa NU are semnalul ăsta!
		if cufar.has_signal(\"cufar_accesat\"):
			cufar.cufar_accesat.connect(_pe_cufar_solicita_quiz)
		else:
			print(\"UȘA: Am ignorat un obiect care nu e cufăr (probabil Masa).\")

# Această funcție trebuie conectată la semnalul body_entered al Area2D-ului copil
func _on_area_2d_body_entered(body: Node2D) -> void:
	if body.name == \"Player\":
		in_door_zone = true

# Această funcție trebuie conectată la semnalul body_exited al Area2D-ului copil
func _on_area_2d_body_exited(body: Node2D) -> void:
	if body.name == \"Player\":
		in_door_zone = false

func _process(_delta: float) -> void:
	# Verificăm dacă jucătorul are cheia (presupunând că ai variabila has_key pe jucător)
	# Sau poți folosi variabila ta 'keytaken' dacă o setezi undeva
	if in_door_zone and Input.is_action_just_pressed(\"accept\") and keytaken:
		open_door()

func open_door():
	$Inchisa.hide() 
	$Deschisa.show() 
	# Dezactivăm coliziunea ca jucătorul să poată trece
	$CollisionShape2D.disabled = true 
	emit_signal(\"door_opened\")
	
	# Funcția care preia apelul de la cufăr
func _pe_cufar_solicita_quiz(subiectul_primit, referinta_cufar):
	cufar_curent_activ = referinta_cufar # Ținem minte ce cufăr a fost atins!
	
	# Declanșăm asaltul AI (apelezi funcția ta care vorbește cu Groq)
	# ex: declanseaza_invatarea(subiectul_primit)
	ai_manager.cere_date_de_la_api(subiectul_primit) 

# MODIFICĂM FINALUL QUIZ-ULUI CA SĂ JUDECE:
func _pe_quiz_terminat(scor: int):
	quiz_ui.hide()
	print(\"COMANDAMENT: Quiz încheiat. Scor: \", scor)
	
	# Dacă a răspuns corect măcar la o întrebare (sau câte vrei tu să setezi limita):
	if scor > 0:
		print(\"COMANDAMENT: Jucătorul a trecut testul! Eliberăm cheia!\")
		if cufar_curent_activ != null:
			cufar_curent_activ.transforma_in_cheie()
			cufar_curent_activ = null
	else:
		print(\"COMANDAMENT: AI PICAT! Mai citește documentația și revino!\")
		# Aici poți printa pe ecran un mesaj, sau pur și simplu nu se întâmplă nimic
		# și jucătorul va trebui să apese iar pe cufăr ca să o ia de la capăt.
		cufar_curent_activ = null
"

